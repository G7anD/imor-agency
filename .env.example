# =====================================================
# imor.agency — environment variables
# =====================================================

# Public site URL (sitemap, OG meta)
NEXT_PUBLIC_SITE_URL=https://imor.agency

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Yandex Metrika
NEXT_PUBLIC_YM_ID=00000000

# =====================================================
# Lead form → Google Sheets
# =====================================================
# 1. Google Cloud Console → Service Account yarating
# 2. Sheet'ni service account email bilan share qiling (Editor)
# 3. JSON key'dan client_email va private_key oling

GOOGLE_SHEETS_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_SHEETS_RANGE=Leads!A:F
GOOGLE_SERVICE_ACCOUNT_EMAIL=imor-leads@your-project.iam.gserviceaccount.com
# private_key — multiline. \n ni saqlang
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# =====================================================
# Telegram notification (optional — yangi lead bo'lganda)
# =====================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
